{
  "manifest_version": 3,
  "name": "Gingify — Tab Memory Manager",
  "version": "1.0.1",
  "description": "Sleep idle tabs to free RAM. Manual control, per-domain rules, real-time dashboard. Zero telemetry. GPL-3.0.",
  "homepage_url": "https://github.com/IshekKhal/gingify",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/sleep_overlay.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "contextMenus",
    "system.memory"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
